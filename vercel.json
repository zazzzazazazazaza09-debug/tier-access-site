{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/stats", "destination": "/api/enter" },
    { "source": "/api/heartbeat", "destination": "/api/me" }
  ]
}
